# ── Eido Environment Configuration ──────────────────────────────────────────
# Copy to .env and fill values. Secrets are injected by Enclii in production.

# App
EIDO_ENV=development
APP_VERSION=0.1.0

# API
API_PORT=8000
API_SECRET_KEY=change-me-in-production
# Shared secret for the orchestration worker → API status callback.
# The API and the worker must carry the identical value.
INTERNAL_API_TOKEN=replace-with-a-strong-shared-secret

# Janua Auth
JANUA_URL=http://localhost:8080
JANUA_JWKS_URL=http://localhost:8080/.well-known/jwks.json   # RS256 — HS256 is fail-closed
JANUA_CLIENT_ID=eido
JANUA_CLIENT_SECRET=dev-secret

# Provisioning credentials — operator-only, used by ops/provision.sh (not app runtime)
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=          # Zone + DNS edit + R2 admin scope

# Object Storage (S3-compatible — MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=eido
S3_SECRET_ACCESS_KEY=eido1234
S3_BUCKET_RAW=eido-raw
S3_BUCKET_CDN=eido-cdn
S3_REGION=us-east-1

# CDN
CDN_BASE_URL=http://localhost:9000/eido-cdn

# Database (PostgreSQL for API metadata)
DATABASE_URL=postgresql+asyncpg://eido:eido@localhost:5432/eido

# Redis (job queue)
REDIS_URL=redis://localhost:6379

# Ecosystem Handoff URLs (Enclii-managed in production)
BLUEPRINT_HARVESTER_URL=http://blueprint-harvester-api:8000
YANTRA4D_URL=http://yantra4d-api:8000
FACTLAS_URL=http://factlas-api:8000
CEQ_URL=http://ceq-api:8000
SELVA_URL=http://autoswarm-api:8000     # LLM inference — never call OpenAI directly
DHANAM_URL=http://dhanam-api:8000        # Billing + entitlement checks

# GPU Orchestration
GPU_PROVIDER=vast          # vast | aws | local
VAST_API_KEY=
AWS_REGION=us-east-1
GPU_WORKER_IMAGE=eido/worker:latest
GPU_MIN_VRAM_GB=24
GPU_MAX_HOURLY_SPEND=8.0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CDN_URL=http://localhost:9000/eido-cdn
NEXT_PUBLIC_JANUA_URL=http://localhost:8080
